rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Coleção de usuários ──────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read: if request.auth != null;

      // Criação do próprio documento: não pode nascer já como admin.
      allow create: if request.auth != null
                     && request.auth.uid == uid
                     && request.resource.data.get('isAdmin', false) == false;

      // Atualização: o próprio usuário pode editar seus dados, mas não pode
      // alterar seu próprio campo isAdmin (só via console/admin SDK).
      allow update: if request.auth != null
                     && request.auth.uid == uid
                     && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false);

      allow delete: if false;
    }

    // ── Salas e subcoleções ──────────────────────────────────────────────
    match /Salas/{salaId} {
      // Qualquer pessoa autenticada pode ver a lista de salas (Consultar Salas)
      allow read: if request.auth != null;
      // Criação de sala: só usuário logado (não anônimo)
      allow create: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
      // Atualização: apenas admin (edição de sala pelo painel admin)
      allow update: if request.auth != null
                     && request.auth.token.firebase.sign_in_provider != 'anonymous'
                     && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true;
      allow delete: if false; // ajuste futuro: apenas o criador da sala

      // ── Participantes (apostas) ────────────────────────────────────────
      match /Participantes/{uid} {
        // Leitura: qualquer autenticado pode ver a lista (tela Participantes)
        allow read: if request.auth != null;

        // Escrita: o próprio usuário (criação/edição da própria aposta) OU admin (marcar verificado)
        allow write: if request.auth != null
                      && request.auth.token.firebase.sign_in_provider != 'anonymous'
                      && (request.auth.uid == uid
                          || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true);
      }

      // ── Mensagens do chat ───────────────────────────────────────────────
      match /Mensagens/{mensagemId} {
        // Leitura: qualquer usuário autenticado (mesmo anônimo) pode LER
        allow read: if request.auth != null;

        // Escrita: só quem está logado (não anônimo) E tem doc em Participantes
        allow create: if request.auth != null
                       && request.auth.token.firebase.sign_in_provider != 'anonymous'
                       && request.auth.uid == request.resource.data.autorUid
                       && request.resource.data.texto is string
                       && request.resource.data.texto.size() > 0
                       && request.resource.data.texto.size() <= 200
                       && exists(/databases/$(database)/documents/Salas/$(salaId)/Participantes/$(request.auth.uid));

        // Mensagens não podem ser editadas ou deletadas (histórico imutável)
        allow update, delete: if false;
      }
    }

    // Regra explícita para collection group queries (ex: painel admin
    // listando apostas pendentes de TODAS as salas de uma vez via
    // collectionGroup('Participantes')). A regra aninhada em
    // Salas/{salaId}/Participantes/{uid} cobre leitura de uma sala por vez,
    // mas não é aplicada a queries de collection group — precisa desta
    // declaração own no nível raiz.
    match /{path=**}/Participantes/{uid} {
      allow read: if request.auth != null;
    }
  }
}
